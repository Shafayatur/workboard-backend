# Django
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — comma separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF — comma separated list, needed for the Django admin login in production
# (must be the full https:// URL of wherever this backend is hosted)
CSRF_TRUSTED_ORIGINS=

# Cloudinary (production image storage) — leave blank for local dev
CLOUDINARY_URL=

# Demo login (used by seed_demo_user management command)
DEMO_USER_EMAIL=demo@workboard.app
DEMO_USER_PASSWORD=DemoPass123!


# Gemini API key (AI task parsing + shape auto-labeling) — get one free at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=